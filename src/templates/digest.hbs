<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI News Digest</title>
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
</head>
<body style="margin:0;padding:0;background-color:#f5f5f5;font-family:-apple-system,'Helvetica Neue',Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f5f5f5;padding:20px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;">

          <!-- ヘッダー -->
          <tr>
            <td style="background-color:#1a1a2e;border-radius:8px 8px 0 0;padding:24px 32px;">
              <h1 style="margin:0;color:#ffffff;font-size:24px;font-weight:700;letter-spacing:-0.5px;">
                <span style="font-family:'Material Icons';font-size:28px;vertical-align:middle;line-height:1;font-weight:normal;font-style:normal;color:#ffffff;margin-right:8px;">smart_toy</span>AI News Digest
              </h1>
              <p style="margin:8px 0 0;color:#a0a0c0;font-size:14px;">
                {{deliveryDate}} ・ {{totalCount}}件の記事
              </p>
            </td>
          </tr>

          {{#if hasTrends}}
          <!-- トレンド分析 -->
          <tr>
            <td style="background-color:#ffffff;padding:24px 32px;border-left:1px solid #e0e0e0;border-right:1px solid #e0e0e0;">
              <h2 style="margin:0 0 16px;font-size:16px;font-weight:700;color:#1a1a2e;border-left:4px solid #1a73e8;padding-left:12px;">
                <span style="font-family:'Material Icons';font-size:20px;vertical-align:middle;line-height:1;font-weight:normal;font-style:normal;color:#1a73e8;margin-right:6px;">trending_up</span>今日のトレンド
              </h2>
              {{#each trends}}
              <div style="margin-bottom:12px;padding:12px 16px;background-color:#f8f9ff;border-radius:6px;">
                <p style="margin:0 0 4px;font-size:14px;font-weight:600;color:#1a1a2e;">{{trend}}</p>
                <p style="margin:0;font-size:13px;color:#555;line-height:1.6;">{{description}}</p>
              </div>
              {{/each}}
            </td>
          </tr>
          {{/if}}

          <!-- カテゴリ別セクション -->
          {{#each categories}}
          <tr>
            <td style="background-color:#ffffff;padding:24px 32px;border-left:1px solid #e0e0e0;border-right:1px solid #e0e0e0;border-top:1px solid #f0f0f0;">
              <h2 style="margin:0 0 16px;font-size:16px;font-weight:700;color:#1a1a2e;border-left:4px solid #34a853;padding-left:12px;">
                <span style="font-family:'Material Icons';font-size:20px;vertical-align:middle;line-height:1;font-weight:normal;font-style:normal;color:#34a853;margin-right:6px;">{{icon}}</span>{{name}} <span style="font-size:13px;font-weight:400;color:#888;">({{articles.length}}件)</span>
              </h2>
              {{#each articles}}
              <div style="margin-bottom:16px;padding:16px;border:1px solid #e8e8e8;border-radius:6px;background-color:#fafafa;">
                <table width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td>
                      <a href="{{url}}" style="text-decoration:none;color:#1a73e8;font-size:15px;font-weight:600;line-height:1.4;">
                        {{truncate title 80}}
                      </a>
                    </td>
                    <td align="right" style="white-space:nowrap;padding-left:8px;">
                      <span style="font-size:11px;color:#999;">{{publishedAt}}</span>
                    </td>
                  </tr>
                </table>
                <p style="margin:8px 0 0;font-size:13px;color:#444;line-height:1.7;">
                  {{summary}}
                </p>
                <p style="margin:8px 0 0;">
                  <span style="font-size:11px;color:#888;background-color:#f0f0f0;padding:2px 6px;border-radius:3px;">
                    {{sourceName}}
                  </span>
                  &nbsp;
                  <a href="{{url}}" style="font-size:12px;color:#1a73e8;text-decoration:none;vertical-align:middle;">
                    <span style="font-family:'Material Icons';font-size:14px;vertical-align:middle;line-height:1;font-weight:normal;font-style:normal;">open_in_new</span> 記事を読む
                  </a>
                </p>
              </div>
              {{/each}}
            </td>
          </tr>
          {{/each}}

          <!-- フッター -->
          <tr>
            <td style="background-color:#f0f0f0;padding:20px 32px;border-radius:0 0 8px 8px;border:1px solid #e0e0e0;border-top:none;">
              <p style="margin:0;font-size:12px;color:#888;text-align:center;">
                このメールは GitHub Actions によって自動送信されています。<br>
                配信停止・設定変更機能は将来のバージョンで追加予定です。
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI News Digest</title>
</head>
<body style="margin:0;padding:0;background-color:#f5f5f5;font-family:-apple-system,'Helvetica Neue',Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f5f5f5;padding:20px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;">

          <!-- ヘッダー -->
          <tr>
            <td style="background-color:#1a1a2e;border-radius:8px 8px 0 0;padding:24px 32px;">
              <h1 style="margin:0;color:#ffffff;font-size:24px;font-weight:700;letter-spacing:-0.5px;">
                ◆ AI News Digest
              </h1>
              <p style="margin:8px 0 0;color:#a0a0c0;font-size:14px;">
                {{deliveryDate}} ・ {{totalCount}}件の記事
              </p>
            </td>
          </tr>

          {{#if hasTrends}}
          <!-- 今週のトレンド（行動提案型） -->
          <tr>
            <td style="background-color:#ffffff;padding:16px 32px;border-left:1px solid #e0e0e0;border-right:1px solid #e0e0e0;">
              <h2 style="margin:0 0 12px;font-size:15px;font-weight:700;color:#1a1a2e;border-left:4px solid #1a73e8;padding-left:10px;">
                ▲ 今週のトレンド
              </h2>
              {{#each trends}}
              <div style="margin-bottom:8px;padding:10px 14px;background-color:#f8f9ff;border-radius:6px;">
                <p style="margin:0 0 3px;font-size:13px;font-weight:600;color:#1a1a2e;">{{trend}}</p>
                <p style="margin:0;font-size:12px;color:#555;line-height:1.6;">{{description}}</p>
                {{#if action}}
                <p style="margin:5px 0 0;font-size:11px;color:#1a73e8;font-weight:600;">→ 試す: {{action}}</p>
                {{/if}}
              </div>
              {{/each}}
            </td>
          </tr>
          {{/if}}

          <!-- カテゴリ別セクション（2カラムグリッド） -->
          {{#each categories}}
          <tr>
            <td style="background-color:#ffffff;padding:16px 32px;border-left:1px solid #e0e0e0;border-right:1px solid #e0e0e0;border-top:1px solid #f0f0f0;">
              <h2 style="margin:0 0 10px;font-size:14px;font-weight:700;color:#1a1a2e;border-left:4px solid #34a853;padding-left:10px;">
                {{icon}} {{name}} <span style="font-size:12px;font-weight:400;color:#888;">({{articles.length}}件)</span>
              </h2>
              {{#each articlePairs}}
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <!-- 左カラム -->
                  <td width="260" style="width:260px;max-width:260px;vertical-align:top;padding-right:5px;">
                    <div style="margin-bottom:8px;padding:12px;border:1px solid #e8e8e8;border-radius:6px;background-color:#fafafa;">
                      <a href="{{left.url}}" style="text-decoration:none;color:#1a73e8;font-size:13px;font-weight:600;line-height:1.4;display:block;margin-bottom:6px;">
                        {{truncate left.title 50}}
                      </a>
                      <p style="margin:0 0 6px;font-size:12px;color:#444;line-height:1.6;">
                        {{truncate left.summary 80}}
                      </p>
                      <table width="100%" cellpadding="0" cellspacing="0">
                        <tr>
                          <td>
                            <span style="font-size:10px;color:#888;background-color:#f0f0f0;padding:2px 5px;border-radius:3px;">{{left.sourceName}}</span>
                            {{#if left.githubUrl}}
                            <a href="{{left.githubUrl}}" style="font-size:10px;color:#fff;background-color:#24292e;padding:2px 5px;border-radius:3px;text-decoration:none;margin-left:4px;">GitHub</a>
                            {{/if}}
                          </td>
                          <td align="right"><span style="font-size:10px;color:#999;">{{left.publishedAt}}</span></td>
                        </tr>
                      </table>
                    </div>
                  </td>
                  <!-- 右カラム -->
                  <td width="260" style="width:260px;max-width:260px;vertical-align:top;padding-left:5px;">
                    {{#if right}}
                    <div style="margin-bottom:8px;padding:12px;border:1px solid #e8e8e8;border-radius:6px;background-color:#fafafa;">
                      <a href="{{right.url}}" style="text-decoration:none;color:#1a73e8;font-size:13px;font-weight:600;line-height:1.4;display:block;margin-bottom:6px;">
                        {{truncate right.title 50}}
                      </a>
                      <p style="margin:0 0 6px;font-size:12px;color:#444;line-height:1.6;">
                        {{truncate right.summary 80}}
                      </p>
                      <table width="100%" cellpadding="0" cellspacing="0">
                        <tr>
                          <td>
                            <span style="font-size:10px;color:#888;background-color:#f0f0f0;padding:2px 5px;border-radius:3px;">{{right.sourceName}}</span>
                            {{#if right.githubUrl}}
                            <a href="{{right.githubUrl}}" style="font-size:10px;color:#fff;background-color:#24292e;padding:2px 5px;border-radius:3px;text-decoration:none;margin-left:4px;">GitHub</a>
                            {{/if}}
                          </td>
                          <td align="right"><span style="font-size:10px;color:#999;">{{right.publishedAt}}</span></td>
                        </tr>
                      </table>
                    </div>
                    {{/if}}
                  </td>
                </tr>
              </table>
              {{/each}}
            </td>
          </tr>
          {{/each}}

          <!-- フッター -->
          <tr>
            <td style="background-color:#f0f0f0;padding:20px 32px;border-radius:0 0 8px 8px;border:1px solid #e0e0e0;border-top:none;">
              <p style="margin:0;font-size:12px;color:#888;text-align:center;">
                このメールは GitHub Actions によって自動送信されています。<br>
                配信停止・設定変更機能は将来のバージョンで追加予定です。
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>

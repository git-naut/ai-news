# Gemini API (https://aistudio.google.com/app/apikey で無料発行)
GEMINI_API_KEY=

# NewsData.io API (https://newsdata.io/api-key で無料発行)
NEWS_API_KEY=

# Gmail 送信設定
# 送信元 Gmail アドレス
GMAIL_USER=your-address@gmail.com
# Google アカウント > セキュリティ > 2段階認証 > アプリパスワード で生成した16文字のパスワード
GMAIL_APP_PASSWORD=

# 配信先メールアドレス（自分自身でも可）
RECIPIENT_EMAIL=recipient@example.com
